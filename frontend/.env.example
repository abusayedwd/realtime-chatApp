# Use same host:port as the browser so httpOnly refresh cookie + middleware work (proxied via next.config rewrites).
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SOCKET_URL=

# Optional — only override when you intentionally talk to Express on another URL (SSR / testing).
BACKEND_INTERNAL_URL=http://127.0.0.1:5000

# Older setup — hits API on :5000 directly; routing after login breaks because cookie is tied to port 5000, not Next.
# NEXT_PUBLIC_API_URL=http://localhost:5000/api
# NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# LAN / ngrok — use the same URL you open in the browser (Next dev/server port), plus internal backend URL:
# NEXT_PUBLIC_API_URL=http://YOUR_LAN_IP:3005/api
# NEXT_PUBLIC_SOCKET_URL=http://YOUR_LAN_IP:3005
# NEXT_DEV_ALLOWED_ORIGINS=YOUR_LAN_IP
# BACKEND_INTERNAL_URL=http://127.0.0.1:5000

NEXT_PUBLIC_WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
