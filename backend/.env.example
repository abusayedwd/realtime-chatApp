NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/chatapp

# JWT  (must be >= 32 chars each, keep these private)
JWT_ACCESS_SECRET=replace_me_with_32+_random_characters
JWT_REFRESH_SECRET=replace_me_with_a_different_32+_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# SMTP (Gmail app password example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="ChatApp <you@gmail.com>"

# Cloudinary (optional — file uploads won't work without these)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Client
CLIENT_URL=http://localhost:3000
